// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            Int      @id @default(autoincrement())
  telegramId    String?  @unique
  email         String   @unique
  name          String?
  role          Role     @default(USER) // "user" | "admin" (логічно через enum потім)
  pointsBalance Int      @default(0)
  passwordHash  String
  emailVerifiedAt                DateTime? @default(now())
  emailVerificationTokenHash     String?   @unique
  emailVerificationTokenExpiresAt DateTime?
  createdAt     DateTime @default(now())

  tasks                 UserTask[]
  transactions          PointsTransaction[]
  registrations         EventRegistration[]
  registrationRequests  EventRegistrationRequest[]
}

model Task {
  id          Int     @id @default(autoincrement())
  title       String
  description String?
  points      Int
  type        String // наприклад: "telegram", "site", "offline"
  isActive    Boolean @default(true)

  PointsTransactions PointsTransaction[]
  userTasks          UserTask[]
}

model Event {
  id              Int       @id @default(autoincrement())
  title           String
  startsAt        DateTime
  endsAt          DateTime?
  latitude        Float?
  longitude       Float?
  city            String?
  country         String?
  venue           String?
  address         String?
  timezone        String    @default("UTC")
  category        String?
  summary         String?
  description     String?
  tags            String[]  @default([])
  capacity        Int?
  spotsLeft       Int?
  host            String?
  registrationUrl String?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  registrations        EventRegistration[]
  registrationRequests EventRegistrationRequest[]
  transactions         PointsTransaction[]
}

model UserTask {
  id            Int      @id @default(autoincrement())
  user          User     @relation(fields: [userId], references: [id])
  userId        Int
  task          Task     @relation(fields: [taskId], references: [id])
  taskId        Int
  completedAt   DateTime @default(now())
  pointsAwarded Int

  @@unique([userId, taskId]) // одне завдання один раз для юзера
}

model PointsTransaction {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id])
  userId    Int
  task      Task?    @relation(fields: [taskId], references: [id])
  taskId    Int?
  event     Event?   @relation(fields: [eventId], references: [id])
  eventId   Int?
  points    Int
  reason    String?
  createdAt DateTime @default(now())
}

model EventRegistration {
  id             Int                     @id @default(autoincrement())
  event          Event                   @relation(fields: [eventId], references: [id])
  eventId        Int
  user           User?                   @relation(fields: [userId], references: [id])
  userId         Int?
  name           String?
  email          String
  contact        String?
  status         EventRegistrationStatus @default(PENDING)
  tokenHash      String?
  tokenExpiresAt DateTime?
  confirmedAt    DateTime?
  createdAt      DateTime                @default(now())

  @@unique([eventId, email])
  @@index([tokenHash])
}

model EventRegistrationRequest {
  id             Int      @id @default(autoincrement())
  event          Event    @relation(fields: [eventId], references: [id])
  eventId        Int
  user           User?    @relation(fields: [userId], references: [id])
  userId         Int?
  name           String?
  email          String
  contact        String?
  tokenHash      String
  tokenExpiresAt DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([eventId, email])
  @@index([tokenHash])
}

enum Role {
  USER
  ADMIN
}

enum EventRegistrationStatus {
  PENDING
  CONFIRMED
}

