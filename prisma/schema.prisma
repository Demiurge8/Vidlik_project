generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                              Int                        @id @default(autoincrement())
  telegramId                      String?                    @unique
  email                           String                     @unique
  name                            String?
  pointsBalance                   Int                        @default(0)
  createdAt                       DateTime                   @default(now())
  passwordHash                    String
  role                            Role                       @default(USER)
  emailVerifiedAt                 DateTime?                  @default(now()) @db.Timestamptz(6)
  emailVerificationTokenHash      String?                    @unique
  emailVerificationTokenExpiresAt DateTime?                  @db.Timestamptz(6)
  registrations                   EventRegistration[]
  registrationRequests            EventRegistrationRequest[]
  transactions                    PointsTransaction[]
  tasks                           UserTask[]
}

model Task {
  id                 Int                 @id @default(autoincrement())
  title              String
  description        String?
  points             Int
  type               String
  isActive           Boolean             @default(true)
  PointsTransactions PointsTransaction[]
  userTasks          UserTask[]
}

model Event {
  id                   Int                        @id @default(autoincrement())
  title                String
  startsAt             DateTime
  description          String?
  isActive             Boolean                    @default(true)
  address              String?
  capacity             Int?
  category             String?
  city                 String?
  country              String?
  createdAt            DateTime                   @default(now())
  endsAt               DateTime?
  host                 String?
  registrationUrl      String?
  spotsLeft            Int?
  summary              String?
  tags                 String[]                   @default([])
  timezone             String                     @default("UTC")
  updatedAt            DateTime                   @updatedAt
  venue                String?
  latitude             Float?
  longitude            Float?
  registrations        EventRegistration[]
  registrationRequests EventRegistrationRequest[]
  transactions         PointsTransaction[]
}

model UserTask {
  id            Int      @id @default(autoincrement())
  userId        Int
  taskId        Int
  completedAt   DateTime @default(now())
  pointsAwarded Int
  task          Task     @relation(fields: [taskId], references: [id])
  user          User     @relation(fields: [userId], references: [id])

  @@unique([userId, taskId])
}

model PointsTransaction {
  id        Int      @id @default(autoincrement())
  userId    Int
  taskId    Int?
  eventId   Int?
  points    Int
  reason    String?
  createdAt DateTime @default(now())
  event     Event?   @relation(fields: [eventId], references: [id])
  task      Task?    @relation(fields: [taskId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}

model EventRegistration {
  id             Int                     @id @default(autoincrement())
  eventId        Int
  userId         Int?
  name           String?
  email          String
  createdAt      DateTime                @default(now())
  contact        String?
  status         EventRegistrationStatus @default(PENDING)
  tokenHash      String?
  tokenExpiresAt DateTime?               @db.Timestamp(6)
  confirmedAt    DateTime?               @db.Timestamp(6)
  event          Event                   @relation(fields: [eventId], references: [id])
  user           User?                   @relation(fields: [userId], references: [id])

  @@unique([eventId, email], map: "eventregistration_eventid_email_key")
  @@index([tokenHash], map: "eventregistration_tokenhash_idx")
}

model EventRegistrationRequest {
  id             Int      @id @default(autoincrement())
  eventId        Int
  userId         Int?
  name           String?
  email          String
  contact        String?
  tokenHash      String
  tokenExpiresAt DateTime @db.Timestamp(6)
  createdAt      DateTime @default(now()) @db.Timestamp(6)
  updatedAt      DateTime @default(now()) @updatedAt @db.Timestamp(6)
  event          Event    @relation(fields: [eventId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user           User?    @relation(fields: [userId], references: [id], onUpdate: NoAction)

  @@unique([eventId, email])
  @@unique([eventId, email], map: "eventregistrationrequest_eventid_email_key")
  @@index([tokenHash])
  @@index([tokenHash], map: "eventregistrationrequest_tokenhash_idx")
}

enum Role {
  USER
  ADMIN
}

enum EventRegistrationStatus {
  PENDING
  CONFIRMED
}
